# ─── Application ───────────────────────────────────────────────────────────
APP_NAME=SLMA Backend
APP_ENV=development

# ─── MongoDB ───────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=slma
MONGODB_SERVER_SELECTION_TIMEOUT_MS=2000

# ─── CORS ──────────────────────────────────────────────────────────────────
# These explicit origins are additive: the backend also allows any private LAN
# range (10.x / 192.168.x / 172.16-31.x) on port 3000 via a regex, so a
# changing DHCP address never requires editing this file.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Auth / session cookie ─────────────────────────────────────────────────
AUTH_COOKIE_NAME=slma_auth
AUTH_SESSION_TTL_MINUTES=480
AUTH_COOKIE_SECURE=false

# ─── Sign recognition model ────────────────────────────────────────────────
# Paths are relative to the slma-backend/ folder.
# The .keras file is distributed separately — see SETUP.md section 3.3
MODEL_PATH=models/slma_best_model_continued_v2.keras
LABEL_ENCODER_PATH=models/slma_label_encoder.json

# Predictions below this softmax confidence are flagged "uncertain"
CONFIDENCE_THRESHOLD=0.3

# ─── CSRE (semantic refinement) ────────────────────────────────────────────
# OPTIONAL. Leave GEMINI_API_KEY blank to use the local rule-based fallback
# engine — the full pipeline still works without any external API.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=10

# ─── First admin account (used by scripts/seed_admin.py) ───────────────────
INITIAL_ADMIN_NAME=
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
